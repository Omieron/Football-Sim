# Copy to .env before: docker compose up -d --build
#
# cp .env.docker.example .env
#
# Web UI:  http://YOUR_SERVER_IP:9010
# API direct (Postman): http://YOUR_SERVER_IP:9011
# API via nginx:        http://YOUR_SERVER_IP:9010/api/...

DB_USER=postgres
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=league

# Public ports on the host (use 9010+ if lower ports are taken)
HTTP_PORT=9010
BACKEND_PORT=9011
